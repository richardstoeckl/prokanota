{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pipeline Configuration",
  "type": "object",
  "required": ["global"],
  "properties": {
    "global": {
      "type": "object",
      "required": ["metadata", "databases", "logs", "interim", "results"],
      "properties": {
        "metadata": {"type": "string", "default": "metadata.csv"},
        "databases": {"type": "string", "default": "databases.yaml"},
        "logs": {"type": "string", "default": "logs"},
        "interim": {"type": "string", "default": "interim"},
        "results": {"type": "string", "default": "results"}
      }
    },
    "features": {
      "type": "object",
      "properties": {
        "translation_table": {
          "type": "integer",
          "minimum": 1,
          "maximum": 25,
          "default": 11
        },
        "meta": {
          "type": "boolean",
          "default": false
        },
        "run_rrna": {
          "type": "boolean",
          "default": true
        },
        "run_trna": {
          "type": "boolean",
          "default": true
        },
        "run_crispr": {
          "type": "boolean",
          "default": true
        },
        "minimum_gene_length": {
          "type": "integer",
          "minimum": 1,
          "default": 90
        }
      }
    }
  }
}
