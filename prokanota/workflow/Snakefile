                python {workflow.basedir}/scripts/diamond_parse.py \
                    --diamond-output {input.diamond_output} \
                    --mapping {input.mapping} \
                    --output {output.tsv} \
                    --db-name {params.db_name} \
                    --mapping-key {params.mapping_key} \
                    --evalue-cutoff {params.evalue_cutoff} \
                    --columns '{params.columns_json}' \
                """ + LOG_REDIRECT

    elif db["search_tool"] == "mmseqs2":

        rule:
            name:
                f"parse_{db_name}"
            input:
                mmseqs_output=os.path.join(INTERIMPATH, "{id}", db_name, "hits.tsv"),
                mapping=db["mapping_path"],
            output:
                tsv=os.path.join(INTERIMPATH, "{id}", db_name, "parsed_annotation.tsv"),
            log:
                os.path.join(LOGPATH, "{id}", "parse", f"parse_{db_name}.log"),
            conda:
                os.path.join(
                    workflow.basedir,
                    "envs",
                    "polars_arm.yaml" if IS_ARM else "polars.yaml",
                )
            threads: 1  # Parsing is single-threaded
            params:
                db_name=db_name,
                mapping_key=db.get("mapping_key", "accession"),
                evalue_cutoff=db.get("evalue_cutoff", 1e-3),
                columns_json=get_columns_json(db),
            message:
                f"Parsing {{wildcards.id}} {db_name} results"
            shell:
