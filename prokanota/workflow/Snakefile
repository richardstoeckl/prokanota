path = metadata.path.to_dict()

if "input_type" in metadata.columns:
    input_type = metadata.input_type.fillna("dna").str.lower().to_dict()
else:
    input_type = {sample_id: "dna" for sample_id in NAMES}

invalid_input_types = [
    sid for sid, itype in input_type.items() if itype not in {"dna", "protein"}
]
if invalid_input_types:
    raise ValueError(
        f"Invalid input_type for samples: {invalid_input_types}. "
        "Allowed values are: dna, protein."
    )

